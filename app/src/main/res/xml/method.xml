<?xml version="1.0" encoding="utf-8"?>
<!--
    IME metadata. supportsSwitchingToNextInputMethod allows the globe key to cycle
    through system IMEs without leaving Big Square Keys.
-->
<input-method
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:settingsActivity="com.bigsquarekeys.settings.SettingsActivity"
    android:supportsSwitchingToNextInputMethod="true">

    <!-- Latin-script subtypes — add locale codes here to expose them in system settings -->
    <subtype
        android:label="@string/subtype_en"
        android:imeSubtypeLocale="en_US"
        android:imeSubtypeMode="keyboard"
        android:isDefault="true" />
    <subtype
        android:label="@string/subtype_en_gb"
        android:imeSubtypeLocale="en_GB"
        android:imeSubtypeMode="keyboard" />
    <subtype
        android:label="@string/subtype_es"
        android:imeSubtypeLocale="es"
        android:imeSubtypeMode="keyboard" />
    <subtype
        android:label="@string/subtype_fr"
        android:imeSubtypeLocale="fr"
        android:imeSubtypeMode="keyboard" />
    <subtype
        android:label="@string/subtype_de"
        android:imeSubtypeLocale="de"
        android:imeSubtypeMode="keyboard" />
    <subtype
        android:label="@string/subtype_it"
        android:imeSubtypeLocale="it"
        android:imeSubtypeMode="keyboard" />
    <subtype
        android:label="@string/subtype_pt"
        android:imeSubtypeLocale="pt"
        android:imeSubtypeMode="keyboard" />
    <subtype
        android:label="@string/subtype_pl"
        android:imeSubtypeLocale="pl"
        android:imeSubtypeMode="keyboard" />
    <subtype
        android:label="@string/subtype_ru"
        android:imeSubtypeLocale="ru"
        android:imeSubtypeMode="keyboard" />
    <subtype
        android:label="@string/subtype_ar"
        android:imeSubtypeLocale="ar"
        android:imeSubtypeMode="keyboard" />

</input-method>
